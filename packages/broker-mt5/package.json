{
  "name": "@forex-bot/broker-mt5",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json --outDir dist",
    "proto:gen": "protoc --plugin=$(pnpm exec which protoc-gen-ts_proto) --ts_proto_out=./src/generated --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true,useExactTypes=false -I ../../proto ../../proto/mt5.proto"
  },
  "dependencies": {
    "@forex-bot/broker-core": "workspace:*",
    "@forex-bot/contracts": "workspace:*",
    "@bufbuild/protobuf": "^2.2.0",
    "@grpc/grpc-js": "^1.12.0"
  },
  "devDependencies": {
    "ts-proto": "^2.2.0"
  }
}
