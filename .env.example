# Local dev env — copy to .env and edit. Sourced by scripts/run-*.sh.

# --- MT5 sidecar (gRPC) ---
MT5_HOST=127.0.0.1
MT5_PORT=50051
# 1 = treat broker as demo (required for paper-runner)
MT5_DEMO=1

# --- Redis (from scripts/dev-up.sh docker-compose) ---
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=forex-bot

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- agent-runner / paper-runner ---
WATCHED_SYMBOLS=EURUSD,USDJPY,XAUUSD
POLL_MS=60000

# --- paper-runner only ---
PAPER_MODE=1
PAPER_BUDGET_USD=50
PAPER_OUT_DIR=./paper-out
